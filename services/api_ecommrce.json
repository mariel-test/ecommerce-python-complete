                  "",
                  "pm.test('Mensaje: Account deleted!', () => {",
                  "    pm.expect(res.message).to.eql('Account deleted!');",
                  "});",
                  "",
                  "// Limpiar variable de email",
                  "pm.collectionVariables.unset('email');",
                  "console.log('Cuenta eliminada exitosamente.');"
                ]
              }
            }
          ]
        }

      ]
